{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "lib": ["ES2022", "DOM"],

    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "resolveJsonModule": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "noEmit": true,

    "types": [
      "node",
      "@playwright/test"
    ]
  },

  "include": [
    "**/*.ts"
  ],

  "exclude": [
    "node_modules",
    "playwright-report",
    "test-results"
  ]
}